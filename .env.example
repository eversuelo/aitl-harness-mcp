# MongoDB
# MONGODB_URI is tried first; MONGODB_URI_FALLBACK is tried if the primary is
# unreachable (cluster down, IP not allowlisted, or local SRV-DNS failure). This lets
# the harness run local AND/OR Atlas without editing config — set Atlas as primary and
# local as fallback (or vice-versa).
MONGODB_URI=mongodb://localhost:27018/?directConnection=true
MONGODB_URI_FALLBACK=
MONGODB_DB=aitl

# Atlas tip: if the SRV form (mongodb+srv://) fails with `querySrv ECONNREFUSED`, your
# host resolver is refusing SRV lookups. Use the non-SRV seedlist form instead (Atlas →
# Connect → "older driver" string), which only needs A records:
# MONGODB_URI=mongodb://USER:PASS@host-00:27017,host-01:27017,host-02:27017/aitl?ssl=true&replicaSet=atlas-xxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# Model backend
# Raw-model providers: openrouter | lmstudio | openai-compat. MODEL_PRIMARY/SECONDARY pick one.
# MODEL_HOST selects an agent host the harness runs OVER (codex | claude-code | antigravity) — planned.
MODEL_PRIMARY=openrouter
MODEL_SECONDARY=openrouter
MODEL_HOST=

# OpenRouter (OpenAI-compatible gateway to many models). Model ids are namespaced, e.g.
# "anthropic/claude-3.5-sonnet", "google/gemini-2.0-flash-exp:free", or "openrouter/auto".
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# LM Studio — local OpenAI-compatible server (free, offline, reproducible runs).
# Start it from the Developer tab ("Start server") or with `lms server start`, then set
# LMSTUDIO_MODEL to the id of the loaded model (shown in the UI / `lms ls`). Pick a model
# with native tool calling (e.g. a qwen-coder class model) — the loop depends on it.
# The server can also listen on the network: point LMSTUDIO_BASE_URL at it if remote.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MAX_CONTEXT=32768

# Generic OpenAI-compatible endpoint (Ollama /v1, vLLM, LiteLLM, private gateways).
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MAX_CONTEXT=128000

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMS=384
VOYAGE_API_KEY=

# Memory synthesis
MEMORY_MAX_DOCS=500
MEMORY_MAX_TOKENS=200000

# Export adapters
ENABLED_ADAPTERS=agents_md

# RBAC bootstrap user (the first user MUST be root).
# If all three values are set and the `users` collection is empty, `aitl check-db`,
# `aitl init-db` and `aitl user bootstrap` create this first user. Per RBAC-REGISTRO,
# the first user must be root; further users are created by an authenticated root via
# `aitl user create`. The password is stored as a salted PBKDF2 hash, never plaintext.
AITL_BOOTSTRAP_USERNAME=
AITL_BOOTSTRAP_EMAIL=
AITL_BOOTSTRAP_PASSWORD=
AITL_BOOTSTRAP_ROLE=root

# RBAC actor mapping (gateways resolve a caller to an Actor).
# Web API: bearer token -> actor. JSON map of token to {id, role}. Unknown/no token
# is treated as an anonymous `user` (least privilege).
AITL_WEB_TOKENS={}
# MCP service identity. The MCP surface acts as an authorized `agent` by default;
# set these to narrow it (e.g. role=auditor for a read-only token).
AITL_MCP_ACTOR_ID=agent:aitl-server
AITL_MCP_ACTOR_ROLE=agent

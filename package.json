{
  "name": "aitl-harness",
  "version": "0.1.0",
  "description": "Agent In The Loop (AITL) — model-agnostic agent harness with durable, structured memory backed by MongoDB Atlas Vector Search. TypeScript port.",
  "type": "module",
  "license": "MIT",
  "author": "Everardo",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aitl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cli.ts",
    "dev:cli": "tsx src/cli.ts",
    "dev:check-db": "tsx scripts/checkDb.ts",
    "dev:init-db": "tsx scripts/initDb.ts",
    "dev:mcp": "tsx src/mcpserver/server.ts",
    "aitl": "tsx src/cli.ts",
    "check-db": "tsx scripts/checkDb.ts",
    "init-db": "tsx scripts/initDb.ts",
    "mcp": "tsx src/mcpserver/server.ts",
    "ui": "tsx src/cli.ts ui",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@google/genai": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.2.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "mongodb": "^6.8.0",
    "openai": "^4.56.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@langchain/langgraph": "^0.2.0",
    "@langchain/langgraph-checkpoint-mongodb": "^0.1.0",
    "@xenova/transformers": "^2.17.2",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
